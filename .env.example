# Django
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# Field encryption (Fernet) - generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# You can keep multiple keys for rotation (comma-separated). First is primary.
FIELD_ENCRYPTION_KEYS=

# CORS (optional)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000

# Database: sqlite or mysql
DB_ENGINE=mysql
DB_NAME=igreja_api
DB_USER=root
DB_PASSWORD=senha
DB_HOST=127.0.0.1
DB_PORT=3306

# Email (password reset)
# For dev, console backend prints emails to the terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@localhost
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Frontend password reset page (optional). Example:
# FRONTEND_RESET_URL=https://app.seudominio.com.br/reset-password
FRONTEND_RESET_URL=
